# Copy this file to .env and fill in your values.
# Never commit your actual .env file — it is gitignored.

# MongoDB connection string (full Atlas URI)
# Get this from the Atlas dashboard → your cluster → Connect → Drivers
# Example: mongodb+srv://username:password@cluster.mongodb.net/Recipe-Ease?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/Recipe-Ease?retryWrites=true&w=majority

# How to create a Database User (if you don't have one):
#   1. Atlas → Security → Database Access → ADD NEW DATABASE USER
#   2. Authentication method: Password
#   3. Built-in role: Atlas Admin
#   4. Copy your username and password into your .env file before clicking Add User
